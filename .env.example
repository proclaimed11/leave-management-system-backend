## Identity service database bootstrap (local/dev)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=identity_svc
DB_SSL=false

## Set true locally to auto-create DB if missing.
## Keep false in managed production environments.
AUTO_CREATE_DB=true
DB_ADMIN_NAME=postgres

## Identity/auth
PORT=3001
NODE_ENV=development
SERVICE_AUTH_TOKEN=replace_me
JWT_SECRET=replace_me
JWT_REFRESH_SECRET=replace_me
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=30d

## Optional integrations
DIRECTORY_SVC_URL=http://localhost:3002
ENTITLEMENT_SVC_URL=http://localhost:3005
INTERNAL_SERVICE_KEY=replace_me
